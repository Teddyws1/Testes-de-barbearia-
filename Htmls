<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xeque-Mate! | Barbearia Premium</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>

        :root {
            --gold: #dfd5a5;
            --bg-main: #0a0a0a;
            --bg-card: #161616;
            --text-color: #ffffff;
            --sidebar-width: 280px;
            --transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        [data-theme="light"] {
            --bg-main: #f8f8f8;
            --bg-card: #ffffff;
            --text-color: #1a1a1a;
            --gold: #8c7336;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body { background-color: var(--bg-main); color: var(--text-color); font-family: 'Montserrat', sans-serif; transition: background 0.4s; overflow-x: hidden; }
        h1, h2, h3, .brand-font { font-family: 'Cinzel', serif; letter-spacing: 2px; }

        /* --- NAVBAR --- */
        nav {
            position: fixed; top: 0; width: 100%; height: 70px;
            padding: 0 5%; display: flex; justify-content: space-between; align-items: center;
            background: var(--bg-card); z-index: 4000; border-bottom: 1px solid var(--gold);
        }
        .menu-btn { width: 45px; height: 45px; border-radius: 50%; background: rgba(223, 213, 165, 0.1); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.3s; z-index: 5000; }

        /* --- SIDEBAR --- */
        .sidebar {
            position: fixed; top: 0; left: calc(-1 * var(--sidebar-width)); 
            width: var(--sidebar-width); height: 100%;
            background: var(--bg-card); z-index: 3000; padding: 100px 20px 30px;
            transition: var(--transition); border-right: 1px solid var(--gold);
            display: flex; flex-direction: column;
        }
        .sidebar.active { left: 0; box-shadow: 10px 0 40px rgba(0,0,0,0.6); }
        .sidebar a { display: flex; align-items: center; gap: 12px; color: var(--text-color); text-decoration: none; padding: 14px; border-radius: 10px; margin-bottom: 8px; transition: 0.2s; }
        .sidebar a i { color: var(--gold); width: 25px; text-align: center; }
        .sidebar a:hover { background: rgba(223, 213, 165, 0.1); transform: translateX(5px); }

        /* --- SIDEBAR FOOTER --- */
        .sidebar-footer { margin-top: auto; padding-top: 20px; border-top: 1px solid rgba(223,213,165,0.1); text-align: center; }
        .social-title { font-family: 'Cinzel', serif; font-size: 0.75rem; color: var(--gold); margin-bottom: 15px; text-transform: uppercase; letter-spacing: 1px; }
        .social-row { display: flex; justify-content: center; gap: 20px; margin-bottom: 20px; }
        .social-btn { width: 45px; height: 45px; border: 1px solid var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--gold); text-decoration: none; transition: 0.3s; background: rgba(223, 213, 165, 0.05); }
        .social-btn:hover { background: var(--gold); color: var(--bg-card); transform: translateY(-3px); }
        .system-version { font-size: 0.65rem; opacity: 0.4; letter-spacing: 1px; font-weight: 600; }

        /* --- CONTEÚDO --- */
        .page-content { display: none; padding: 100px 5% 60px; animation: fadeIn 0.4s ease; }
        .page-content.active { display: block; }
        
        /* --- ESTILO DA HISTÓRIA LONGA --- */
        .story-container { max-width: 900px; margin: 0 auto; line-height: 1.8; text-align: justify; }
        .story-image { width: 100%; height: 400px; object-fit: cover; border-radius: 15px; border: 1px solid var(--gold); margin-bottom: 30px; }
        .story-title { font-size: 2rem; color: var(--gold); text-align: center; margin-bottom: 25px; }
        .story-columns { column-count: 2; column-gap: 40px; margin-top: 20px; color: rgba(255,255,255,0.85); }
        [data-theme="light"] .story-columns { color: #333; }
        
        @media (max-width: 768px) {
            .story-columns { column-count: 1; }
            .story-image { height: 250px; }
        }

        /* --- SCROLLERS (FOTOS/VIDEOS) --- */
        .scroller-container { margin-bottom: 25px; }
        .scroller { display: flex; overflow-x: auto; gap: 15px; padding: 15px 0; scroll-snap-type: x mandatory; scrollbar-width: none; }
        .scroller::-webkit-scrollbar { display: none; }
        .card { min-width: 240px; width: 240px; height: 320px; background: var(--bg-card); border: 1px solid rgba(223, 213, 165, 0.2); border-radius: 12px; overflow: hidden; position: relative; scroll-snap-align: start; transition: 0.3s; cursor: pointer; }
        .card:hover { border-color: var(--gold); transform: scale(1.02); }
        .card img, .card video { width: 100%; height: 100%; object-fit: cover; }
        .item-id { position: absolute; top: 10px; left: 10px; background: rgba(0,0,0,0.8); color: var(--gold); padding: 2px 8px; font-size: 0.65rem; border: 1px solid var(--gold); z-index: 10; border-radius: 4px; }

        /* --- LIGHTBOX --- */
        #lightbox { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 6000; display: none; justify-content: center; align-items: center; opacity: 0; transition: opacity 0.4s ease; }
        #lightbox.active { display: flex; opacity: 1; }
        #lightbox img { max-width: 90%; max-height: 85%; border: 2px solid var(--gold); border-radius: 8px; transform: scale(0.9); transition: transform 0.4s ease; }
        #lightbox.active img { transform: scale(1); }
        .close-lightbox { position: absolute; top: 25px; right: 25px; color: var(--gold); font-size: 2rem; cursor: pointer; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 2500; display: none; }
        .overlay.active { display: block; }
    </style>
</head>
<body data-theme="dark">

    <div class="overlay" id="overlay"></div>

    <div id="lightbox">
        <span class="close-lightbox" id="closeLightbox">&times;</span>
        <img src="" id="lightboxImg">
    </div>

    <nav>
        <div class="menu-btn" id="menuBtn"><i class="fas fa-bars" style="color:var(--gold)"></i></div>
        <div class="brand-font" style="color:var(--gold); font-size: 1.1rem;">XEQUE-MATE!</div>
        <i class="fas fa-moon theme-toggle" id="themeToggle" style="color:var(--gold); cursor:pointer; font-size: 1.2rem;"></i>
    </nav>

    <aside class="sidebar" id="sidebar">
        <a href="javascript:void(0)" onclick="setPage('historia')"><i class="fas fa-chess-rook"></i> História</a>
        <a href="javascript:void(0)" onclick="setPage('fotos')"><i class="fas fa-images"></i> Portfólio Fotos</a>
        <a href="javascript:void(0)" onclick="setPage('videos')"><i class="fas fa-video"></i> Galeria Vídeos</a>
        <a href="javascript:void(0)" onclick="setPage('local')"><i class="fas fa-map-marked-alt"></i> Localização</a>
        
        <div class="sidebar-footer">
            <h4 class="social-title">Siga a Barbearia</h4>
            <div class="social-row">
                <a href="#" class="social-btn" title="Instagram"><i class="fab fa-instagram"></i></a>
                <a href="#" class="social-btn" title="Facebook"><i class="fab fa-facebook-f"></i></a>
            </div>
            <div class="system-version">SISTEMA v4.5.0 | TEDDY MACHADO</div>
        </div>
    </aside>

    <section id="historia" class="page-content active">
        <div class="story-container">
            <h2 class="story-title brand-font">Tradição & Estilo</h2>
            <img src="https://images.unsplash.com/photo-1585747860715-2ba37e788b70?w=1200&q=80" class="story-image" alt="Interior da Barbearia">
            
            <div class="story-columns">
                <p>
                    Fundada com o objetivo de elevar o conceito de estética masculina em Frederico Westphalen, a <strong>Xeque-Mate! Barbearia Premium</strong> nasceu da paixão pelo detalhe e pela arte da barbearia clássica. Entendemos que o corte de cabelo e o cuidado com a barba não são apenas serviços, mas momentos de renovação e autoestima para o homem moderno.
                </p>
                <br>
                <p>
                    Nosso espaço foi meticulosamente planejado para oferecer um refúgio de sofisticação e conforto. Aliamos as técnicas tradicionais de toalha quente e navalha afiada às tendências mais atuais de visagismo internacional. Na Xeque-Mate!, cada cliente é tratado de forma única, garantindo que sua imagem reflita sua personalidade e autoridade.
                </p>
                <br>
                <p>
                    Mais do que uma barbearia, somos um ponto de encontro. Um lugar onde a conversa flui, o café é de qualidade e o resultado final é sempre impecável. Nossa equipe é composta por profissionais altamente qualificados que buscam constantemente a perfeição em cada ângulo e em cada fio.
                </p>
                <br>
                <p>
                    Seja para um corte executivo discreto ou para um visual arrojado e moderno, a Xeque-Mate! é o seu destino final. Convidamos você a fazer o seu movimento e descobrir por que somos a referência em cuidado premium na região. O seu estilo merece esse próximo passo.
                </p>
            </div>
        </div>
    </section>

    <section id="fotos" class="page-content">
        <h2 class="brand-font" style="color: var(--gold); padding:0 0 20px; text-align:center;">Portfólio</h2>
        <div class="scroller-container"><div class="scroller" id="img-row-1"></div></div>
        <div class="scroller-container"><div class="scroller" id="img-row-2"></div></div>
        <div class="scroller-container"><div class="scroller" id="img-row-3"></div></div>
    </section>

    <section id="videos" class="page-content">
        <h2 class="brand-font" style="color: var(--gold); padding:0 0 20px; text-align:center;">Galeria</h2>
        <div class="scroller-container"><div class="scroller" id="vid-row-1"></div></div>
        <div class="scroller-container"><div class="scroller" id="vid-row-2"></div></div>
        <div class="scroller-container"><div class="scroller" id="vid-row-3"></div></div>
    </section>

    <section id="local" class="page-content">
        <div style="height: 400px; border-radius: 12px; overflow: hidden; border: 1px solid var(--gold);">
            <iframe src="http://googleusercontent.com/maps.google.com/9" width="100%" height="100%" style="border:0;"></iframe>
        </div>
    </section>

    <script>
        function initApp() {
            for(let row = 1; row <= 3; row++) {
                const imgRow = document.getElementById(`img-row-${row}`);
                const vidRow = document.getElementById(`vid-row-${row}`);

                for(let i = 1; i <= 10; i++) {
                    let id = (row-1)*10 + i;
                    let idTxt = id < 10 ? '0'+id : id;

                    imgRow.innerHTML += `
                        <div class="card" onclick="openZoom('https://picsum.photos/600/800?random=${id}')">
                            <span class="item-id">#IMG-${idTxt}</span>
                            <img loading="lazy" src="https://picsum.photos/400/600?random=${id}">
                        </div>`;

                    vidRow.innerHTML += `
                        <div class="card">
                            <span class="item-id">#VID-${idTxt}</span>
                            <video preload="none" poster="https://picsum.photos/400/600?grayscale&random=${id}" controls>
                                <source src="v${id}.mp4">
                            </video>
                        </div>`;
                }
            }
        }
        initApp();

        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightboxImg');

        function openZoom(src) {
            lightboxImg.src = src;
            lightbox.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeZoom() {
            lightbox.classList.remove('active');
            document.body.style.overflow = 'auto';
        }

        document.getElementById('closeLightbox').onclick = closeZoom;
        lightbox.onclick = (e) => { if (e.target !== lightboxImg) closeZoom(); };

        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('overlay');
        const menuBtn = document.getElementById('menuBtn');

        function toggleSidebar() {
            sidebar.classList.toggle('active');
            overlay.classList.toggle('active');
        }

        menuBtn.onclick = toggleSidebar;
        overlay.onclick = toggleSidebar;

        function setPage(id) {
            document.querySelectorAll('.page-content').forEach(p => p.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            if(sidebar.classList.contains('active')) toggleSidebar();
            window.scrollTo(0,0);
        }

        document.getElementById('themeToggle').onclick = function() {
            const body = document.body;
            const isDark = body.getAttribute('data-theme') === 'dark';
            body.setAttribute('data-theme', isDark ? 'light' : 'dark');
            this.className = isDark ? 'fas fa-adjust' : 'fas fa-moon';
        };
    </script>
</body>
</html>
